#!/usr/bin/env bash
# pr-review-consensus — Set PR description to multi-LLM consensus; collapse review comments.
#
# After pr-review-relay rounds, synthesize consensus (agent/human), save markdown, then:
#
#   pr-review-consensus --consensus-file reviews/my-pr-consensus.md
#
# Usage:
#   pr-review-consensus --consensus-file path.md [--pr N] [--no-collapse]
#   pr-review-consensus --consensus-file path.md --append-original
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COLLAPSE="$SCRIPT_DIR/pr-review-collapse-comments"

PR=""; CONSENSUS_FILE=""; NO_COLLAPSE=0; APPEND_ORIGINAL=0

while [ $# -gt 0 ]; do
  case "$1" in
    --pr)              PR="$2"; shift 2;;
    --consensus-file)  CONSENSUS_FILE="$2"; shift 2;;
    --no-collapse)     NO_COLLAPSE=1; shift;;
    --append-original) APPEND_ORIGINAL=1; shift;;
    -h|--help)
      sed -n '2,12p' "$0"
      exit 0;;
    *) echo "unknown arg: $1" >&2; exit 2;;
  esac
done

[ -n "$CONSENSUS_FILE" ] || { echo "Pass --consensus-file PATH (markdown consensus work card)." >&2; exit 1; }
[ -f "$CONSENSUS_FILE" ] || { echo "Not found: $CONSENSUS_FILE" >&2; exit 1; }
command -v gh >/dev/null || { echo "gh CLI required." >&2; exit 1; }

[ -z "$PR" ] && PR="$(gh pr view --json number -q .number 2>/dev/null || true)"
[ -n "$PR" ] || { echo "No PR found. Pass --pr N or run from a PR branch." >&2; exit 1; }

PR_URL="$(gh pr view "$PR" --json url -q .url 2>/dev/null || true)"
REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)"

echo "▶ PR review consensus"
echo "  pr:   #$PR ${PR_URL:+($PR_URL)}"
echo "  file: $CONSENSUS_FILE"

BODY_FILE="$(mktemp)"
{
  if [ -n "$PR_URL" ]; then
    echo "**PR:** $PR_URL"
    echo ""
  fi
  cat "$CONSENSUS_FILE"
  echo ""
  if [ "$APPEND_ORIGINAL" = 1 ]; then
    ORIG="$(gh pr view "$PR" --json body -q .body 2>/dev/null || true)"
    if [ -n "${ORIG// }" ]; then
      echo "<details>"
      echo "<summary>Original PR description (before consensus)</summary>"
      echo ""
      printf '%s\n' "$ORIG"
      echo ""
      echo "</details>"
      echo ""
    fi
  fi
  echo "---"
  echo "<sub>via pr-review-consensus</sub>"
} > "$BODY_FILE"

gh pr edit "$PR" --body-file "$BODY_FILE" >/dev/null \
  || { echo "Failed to update PR body." >&2; rm -f "$BODY_FILE"; exit 1; }
rm -f "$BODY_FILE"

echo "  ✓ PR description updated with consensus"

if [ "$NO_COLLAPSE" = 0 ]; then
  "$COLLAPSE" --pr "$PR"
else
  echo "  (skipped comment collapse)"
fi

echo "✔ Consensus applied on PR #$PR"
