#!/usr/bin/env bash
# pr-review-relay — hand a PR off to the OTHER agents for cross-review.
#
# Whoever created the PR calls this with --author <self>. The other agents
# (claude / codex / cursor / antigravity / opencode) review the PR headless +
# read-only and post their review as a PR comment. The author auto-excludes itself.
#
# By default the reviewers are handed the PR *reference* and fetch it themselves
# (gh pr view/diff) — they get the full PR: title, body, discussion, and every
# changed file in context, not just a diff snapshot. Pass --diff for the older
# diff-on-stdin behaviour. Pass --context-file <path> to prepend a document
# (docs, specs, API references) that every reviewer must read and verify against.
#
# Each review is posted COLLAPSED (<details>/<summary>, forum-style hide/show)
# so the PR page stays clean — expand a comment to read it. After consensus,
# put the synthesized work card in the PR description with pr-review-consensus.
#
# Usage:
#   pr-review-relay [--author claude|codex|cursor|antigravity] [--pr <number|url>] \
#                   [--reviewers claude,codex,cursor,antigravity] [--parallel] \
#                   [--context-file <path>] [--diff] [--dry-run]
#   (no --pr → uses the PR for the current branch; run from inside the repo)
#
# Fail-closed exit codes (so callers can trust the outcome, not just the banner):
#   0  every reviewer that ran produced AND posted a review; PR head did not move.
#      NOTE: this means everyone RAN — not that the PR is approved. You still must
#      read the reviews and resolve every Blocker/Should-fix before merging.
#   3  not a clean round: a reviewer returned empty / timed out / exited non-zero /
#      failed to post, OR an explicitly-requested reviewer was missing, OR no
#      reviewer ran, OR HEAD moved during the round (reviews now describe stale code).
#   4  review-round cap reached — stop looping and escalate to a human.
#   1/2 usage or precondition error (no gh, no PR, empty diff, bad arg).
# A missing CLI from the DEFAULT reviewer set is a tolerated skip; only reviewers
# named explicitly via --reviewers are required to be present.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WRAP_COMMENT="$SCRIPT_DIR/wrap-collapsed-pr-comment.mjs"

AUTHOR=""; PR=""; REVIEWERS="claude,codex,cursor,antigravity"; PARALLEL=0; DRY=0; MAX_ROUNDS="${PR_RELAY_MAX_ROUNDS:-3}"; RESET=0; AGENT_TIMEOUT="${PR_RELAY_AGENT_TIMEOUT:-300}"
CONTEXT_FILE=""; MODE="link"; REVIEWERS_EXPLICIT=0
while [ $# -gt 0 ]; do
  case "$1" in
    --author)       AUTHOR="$2"; shift 2;;
    --pr)           PR="$2"; shift 2;;
    --reviewers)    REVIEWERS="$2"; REVIEWERS_EXPLICIT=1; shift 2;;
    --parallel)     PARALLEL=1; shift;;
    --context-file) CONTEXT_FILE="$2"; shift 2;;
    --diff)         MODE="diff"; shift;;
    --link)         MODE="link"; shift;;
    --dry-run)      DRY=1; shift;;
    --max-rounds)   MAX_ROUNDS="$2"; shift 2;;
    --reset)        RESET=1; shift;;
    -h|--help)      awk 'NR>1 && /^#/{sub(/^# ?/,"");print;next} NR>1{exit}' "$0"; exit 0;;
    *) echo "unknown arg: $1" >&2; exit 2;;
  esac
done

command -v gh >/dev/null || { echo "gh not found"; exit 1; }
case "$AUTHOR" in agy) AUTHOR=antigravity;; esac
[ -z "$PR" ] && PR=$(gh pr view --json number -q .number 2>/dev/null)
[ -z "$PR" ] && { echo "No PR found for the current branch. Pass --pr <n>."; exit 1; }
PR_URL=$(gh pr view "$PR" --json url -q .url 2>/dev/null || true)
REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)
# Reviewed SHA: bind every review to the exact PR head so a concurrent push can't
# leave green reviews standing on stale code (checked again at the end).
HEAD_SHA=$(gh pr view "$PR" --json headRefOid -q .headRefOid 2>/dev/null || true)
echo "▶ Relay review for PR #$PR ${PR_URL:+($PR_URL)} — author: ${AUTHOR:-none} — mode: $MODE${HEAD_SHA:+ — sha: ${HEAD_SHA:0:7}}"
# Fail-closed early: if we can't even read the head SHA now, we'll never be able to
# prove HEAD stayed put — abort before spending reviewer runs (a dry-run needs no SHA).
if [ "$DRY" = 0 ] && [ -z "$HEAD_SHA" ]; then
  echo "✖ Could not read PR head SHA — cannot prove HEAD stability. Re-run." >&2; exit 3
fi

# Per-reviewer outcome, written as files so it survives subshells under --parallel:
# $STATUS_DIR/<key> is "pending" (pre-seeded), "ok", or "fail". A reviewer that is
# hard-killed before writing leaves its pre-seeded "pending" → counted as a failure.
STATUS_DIR="$(mktemp -d)" || { echo "cannot create temp dir for outcome tracking" >&2; exit 1; }
trap 'rm -rf "$STATUS_DIR"' EXIT
# Map a reviewer name to a safe filename so a crafted --reviewers value (e.g.
# "../../etc/foo") can never escape STATUS_DIR and clobber a file. The fixed "k_"
# prefix also guarantees the key is never a dotfile (which the tally glob "*"
# would silently skip) or "."/".." — either would reopen a fail-open hole.
status_key() { printf 'k_%s' "$(printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_')"; }

DIFF=$(gh pr diff "$PR" 2>/dev/null)
[ -z "$DIFF" ] && { echo "Empty diff or cannot read PR #$PR."; exit 1; }
echo "  diff: $(printf '%s' "$DIFF" | wc -l) lines, $(printf '%s' "$DIFF" | wc -c) bytes"

# --- Optional context document prepended to every reviewer's prompt ----------
CONTEXT_BLOCK=""
if [ -n "$CONTEXT_FILE" ]; then
  [ -f "$CONTEXT_FILE" ] || { echo "context file not found: $CONTEXT_FILE" >&2; exit 1; }
  CONTEXT_BLOCK=$(printf '## Provided context — read this and verify the PR against it\n\n%s\n\n---\n\n' "$(cat "$CONTEXT_FILE")")
  echo "  context: $CONTEXT_FILE ($(wc -c < "$CONTEXT_FILE") bytes)"
fi

# --- Hard loop guard: cap the number of review rounds per PR ---------------
# Prevents an endless read→fix→re-run cycle. Counter is per repo+PR, kept in a
# cache file; auto-resets after 6h of inactivity (a fresh working session), or
# manually with --reset. A round is only CONSUMED once at least one reviewer
# actually ran (see end of file) — a misconfigured machine where nobody runs
# won't march the counter to the cap without ever getting a review.
ROUND_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/pr-review-relay"; mkdir -p "$ROUND_DIR"
ROUND_KEY=$(printf '%s#%s' "${REPO:-unknown}" "$PR" | tr -c 'A-Za-z0-9._#-' '_')
ROUND_FILE="$ROUND_DIR/$ROUND_KEY.round"
[ "$RESET" = 1 ] && rm -f "$ROUND_FILE"
if [ -f "$ROUND_FILE" ] && [ $(( $(date +%s) - $(stat -c %Y "$ROUND_FILE" 2>/dev/null || echo 0) )) -gt 21600 ]; then
  rm -f "$ROUND_FILE"   # stale (>6h): new session, start fresh
fi
ROUND=$(cat "$ROUND_FILE" 2>/dev/null || echo 0)
if [ "$ROUND" -ge "$MAX_ROUNDS" ]; then
  echo "⛔ Review round cap reached for $REPO#$PR ($ROUND/$MAX_ROUNDS)." >&2
  echo "   STOP the review loop: do NOT run the relay again on this PR. Address any" >&2
  echo "   remaining items manually, or pass --reset to force another round." >&2
  exit 4   # distinct code: not a clean pass — escalate, don't treat as consensus
fi
echo "  review round: $((ROUND + 1))/$MAX_ROUNDS"

# --- Build the review prompt -------------------------------------------------
if [ "$MODE" = diff ]; then
  read -r -d '' BASE <<'P' || true
You are reviewing a pull request. Review the diff (provided on stdin) for correctness
bugs, security issues, broken edge cases, and clear design/maintainability problems.
You may read files in the current repo for context, but DO NOT modify anything.
Be concise. Group findings by severity: Blocker / Should-fix / Nit.
If it looks good, say so in one line.
P
else
  read -r -d '' BASE <<P || true
You are reviewing an OPEN pull request: PR #$PR in $REPO ${PR_URL:+($PR_URL)}.
Go read it YOURSELF before reviewing — you have read-only repo + gh access:
  gh pr view $PR      # title, body, discussion
  gh pr diff $PR      # the change
Read the files the diff touches (and anything the PR or the context above references)
for full context — not just the diff. Then review for correctness bugs, security
issues, broken edge cases, and clear design/maintainability problems. DO NOT modify
anything. Be concise. Group findings by severity: Blocker / Should-fix / Nit.
If it looks good, say so in one line.
P
fi
PROMPT="${CONTEXT_BLOCK}${BASE}"
# Link mode embeds the diff as a FALLBACK so no reviewer comes back empty if its
# sandbox can't run `gh`. Capable agents still fetch the
# full PR per the prompt; this is only a safety net.
# BUT: a huge inline diff blows past some agents' prompt limits and makes them
# return empty (observed with codex/antigravity on 100KB+ PRs). Above a size
# threshold, omit the fallback so the prompt stays small and reviewers fetch the
# PR themselves via `gh` (the whole point of link mode). Tune via env
# LINK_DIFF_FALLBACK_MAX_BYTES (default 100000; set 0 to always omit).
LINK_DIFF_FALLBACK_MAX_BYTES="${LINK_DIFF_FALLBACK_MAX_BYTES:-100000}"
if [ "$MODE" = link ]; then
  _diff_bytes=$(printf '%s' "$DIFF" | wc -c | tr -d ' ')
  if [ "$_diff_bytes" -le "$LINK_DIFF_FALLBACK_MAX_BYTES" ]; then
    PROMPT=$(printf '%s\n\n---\n## Fallback: the PR diff\nPrefer fetching the full PR with the `gh` commands above — you get the whole changed files, not just these hunks. If your sandbox cannot run `gh`, review this diff instead so you never return empty:\n\n```diff\n%s\n```\n' "$PROMPT" "$DIFF")
  else
    echo "  (diff ${_diff_bytes}B > ${LINK_DIFF_FALLBACK_MAX_BYTES}B — omitting inline fallback; reviewers fetch the PR via gh)"
  fi
fi

tool_for() { case "$1" in claude) echo claude;; codex) echo codex;; cursor) echo cursor-agent;; antigravity|agy) echo agy;; opencode) echo opencode;; *) echo "";; esac; }

review_with() {
  local name="$1" out="" feed="" rc=0 errf skey
  skey="$(status_key "$name")"
  errf="$(mktemp)"
  [ "$MODE" = diff ] && feed="$DIFF"   # only diff mode pipes the diff; link mode fetches it
  case "$name" in
    claude)       out=$(printf '%s' "$feed" | timeout "$AGENT_TIMEOUT" claude -p "$PROMPT" 2>"$errf"); rc=$?;;
    codex)        out=$(printf '%s' "$feed" | timeout "$AGENT_TIMEOUT" codex exec -s danger-full-access "$PROMPT" 2>"$errf"); rc=$?;;
    cursor)
      if [ "$MODE" = diff ]; then
        out=$(printf '%s\n\n%s' "$PROMPT" "$DIFF" | timeout "$AGENT_TIMEOUT" cursor-agent -p --trust --mode=ask 2>"$errf")
      else
        out=$(printf '%s' "$PROMPT" | timeout "$AGENT_TIMEOUT" cursor-agent -p --trust --mode=ask 2>"$errf")
      fi; rc=$?;;
    antigravity)
      if [ "$MODE" = diff ]; then
        out=$(timeout "$AGENT_TIMEOUT" agy --dangerously-skip-permissions -p "$(printf '%s\n\n%s' "$PROMPT" "$DIFF")" 2>"$errf")
      else
        out=$(timeout "$AGENT_TIMEOUT" agy --dangerously-skip-permissions -p "$PROMPT" 2>"$errf")
      fi; rc=$?;;
    opencode)
      if [ "$MODE" = diff ]; then
        out=$(timeout "$AGENT_TIMEOUT" opencode run --dangerously-skip-permissions "$(printf '%s\n\n%s' "$PROMPT" "$DIFF")" 2>"$errf")
      else
        out=$(timeout "$AGENT_TIMEOUT" opencode run --dangerously-skip-permissions "$PROMPT" 2>"$errf")
      fi; rc=$?;;
  esac
  # Never fail silently: if the agent produced no review, say why in human terms
  # and show what it wrote on stderr. "Empty" means no non-whitespace content, so
  # a tab/newline-only reply doesn't slip through as a valid review.
  if [ -z "$(printf '%s' "$out" | tr -d '[:space:]')" ]; then
    local why="exited with code $rc"
    case "$rc" in
      0)   why="ran fine but returned an empty review";;
      124) why="timed out after ${AGENT_TIMEOUT}s (raise PR_RELAY_AGENT_TIMEOUT)";;
      126) why="found but could not be executed (exit 126)";;
      127) why="command not found";;
    esac
    echo "  ! $name: no review — $why" >&2
    # On timeout stderr only holds the agent's partial transcript — skip it.
    if [ "$rc" != 124 ] && [ -s "$errf" ]; then
      echo "    $name stderr (last 15 lines):" >&2
      tail -n 15 "$errf" | sed 's/^/    │ /' >&2
    fi
    echo fail > "$STATUS_DIR/$skey"   # no output → round is not clean
    rm -f "$errf"; return 0
  fi
  local unclean=0
  if [ "$rc" -ne 0 ]; then
    # Produced a review but the CLI exited non-zero: the review may be truncated,
    # so the round is NOT clean even though we still post what we got (informative).
    echo "  ! $name: exited with code $rc — review may be truncated (round not clean)" >&2
    unclean=1
  fi
  rm -f "$errf"
  local icon; case "$name" in claude) icon="🟣";; codex) icon="🟢";; cursor) icon="🔵";; antigravity) icon="🟠";; opencode) icon="⚪";; *) icon="🤖";; esac
  # Echo the review to stdout so the agent that launched the relay can read it,
  # address the findings, push, and re-run (the iterate loop). Single printf to
  # stay roughly atomic under --parallel.
  printf '\n========== %s review ==========\n%s\n===============================\n' "${name^}" "$out"
  # idempotent: remove any previous review from the SAME agent on this PR
  if [ -n "$REPO" ]; then
    for id in $(gh api --paginate "repos/$REPO/issues/$PR/comments" \
                  --jq ".[] | select(.body|contains(\"${name^} review (automated cross-review)\")) | .id" 2>/dev/null); do
      gh api -X DELETE "repos/$REPO/issues/comments/$id" >/dev/null 2>&1 || true
    done
  fi
  # Post the review COLLAPSED: wrap it in <details>/<summary> via the helper so
  # the PR page shows a one-line toggle (forum-style hide/show) per reviewer.
  local footer comment_body out_file
  footer="<sub>via pr-review-relay · author: ${AUTHOR:-?}${CONTEXT_FILE:+ · context: $(basename "$CONTEXT_FILE")}${HEAD_SHA:+ · reviewed sha: ${HEAD_SHA:0:7}}</sub>"
  comment_body="$(mktemp)"; out_file="$(mktemp)"
  printf '%s' "$out" > "$out_file"
  # If the wrapper fails (node missing/broken) or yields an empty body, do NOT post
  # a broken/partial comment and mark ok — treat it as a failed reviewer.
  if ! node "$WRAP_COMMENT" \
        --summary "${icon} ${name^} review (automated cross-review)" \
        --footer "$footer" \
        --file "$out_file" > "$comment_body" || [ ! -s "$comment_body" ]; then
    echo "  ! $name: could not render comment (wrapper failed / empty output)" >&2
    echo fail > "$STATUS_DIR/$skey"
    rm -f "$out_file" "$comment_body"; return 0
  fi
  rm -f "$out_file"
  if gh pr comment "$PR" --body-file "$comment_body" >/dev/null; then
    echo "  ✓ $name review posted (collapsed)"
    [ "$unclean" = 1 ] && echo fail > "$STATUS_DIR/$skey" || echo ok > "$STATUS_DIR/$skey"
  else
    echo "  ! $name: failed to post comment" >&2
    echo fail > "$STATUS_DIR/$skey"   # review not visible on the PR → not clean
  fi
  rm -f "$comment_body"
}

IFS=',' read -ra LIST <<< "$REVIEWERS"
# dedupe: same reviewer twice would share one status file (race under --parallel).
# Space-delimited string, not an assoc array, so this stays Bash 3.2-safe (macOS).
SEEN_LIST=""
would_run=0; skipped=0   # reviewers that would run / were tolerated-skipped (default set)
for r in "${LIST[@]}"; do
  r="${r// }"
  [ -z "$r" ] && continue           # tolerate empty items (e.g. "claude,,codex")
  [ "$r" = "agy" ] && r=antigravity
  [ "$r" = "$AUTHOR" ] && { echo "  – skip $r (author)"; continue; }
  rkey="$(status_key "$r")"          # rkey has no spaces, so the string check is safe
  case " $SEEN_LIST " in *" $rkey "*) echo "  – skip $r (duplicate)"; continue;; esac
  SEEN_LIST="$SEEN_LIST $rkey"
  local_tool=$(tool_for "$r")
  if [ -z "$local_tool" ]; then
    if [ "$REVIEWERS_EXPLICIT" = 1 ]; then echo "  ! unknown reviewer '$r' (explicitly requested → fail)" >&2; echo fail > "$STATUS_DIR/$rkey"; else echo "  ! unknown reviewer '$r' (skip)"; fi
    continue
  fi
  if ! command -v "$local_tool" >/dev/null; then
    # Not installed: a hard failure only if the user explicitly asked for this
    # reviewer; for the default set it's a tolerated skip (users have different CLIs).
    if [ "$REVIEWERS_EXPLICIT" = 1 ]; then echo "  ! $local_tool not installed but explicitly requested → fail" >&2; echo fail > "$STATUS_DIR/$rkey"; else echo "  ! $local_tool not installed (skip $r)"; skipped=$((skipped + 1)); fi
    continue
  fi
  would_run=$((would_run + 1))
  if [ "$DRY" = 1 ]; then echo "  · would run: $r ($local_tool)"; continue; fi
  echo "  → $r reviewing…"
  # Pre-seed "pending": if the reviewer is hard-killed before it can record its
  # own outcome, this file survives and the tally counts it as a failure (not a
  # silent exclusion that could let the round pass clean).
  echo pending > "$STATUS_DIR/$rkey"
  if [ "$PARALLEL" = 1 ]; then review_with "$r" & else review_with "$r"; fi
done
[ "$PARALLEL" = 1 ] && wait

# --- Fail-closed verdict -----------------------------------------------------
# Tally per-reviewer outcomes recorded under $STATUS_DIR (pending/ok/fail).
ran=0; failed=0; failed_names=""
for f in "$STATUS_DIR"/*; do
  [ -e "$f" ] || continue
  ran=$((ran + 1))
  if [ "$(cat "$f")" != ok ]; then n="${f##*/}"; failed=$((failed + 1)); failed_names="$failed_names ${n#k_}"; fi
done

# In --dry-run no reviewer executes, but explicitly-requested reviewers that are
# unknown/missing DO record a failure above — surface that as a non-zero preflight
# instead of a false clean pass. Zero runnable reviewers is also a failed preflight.
if [ "$DRY" = 1 ]; then
  if [ "$failed" -gt 0 ]; then echo "✖ Dry run: invalid --reviewers config —$failed_names." >&2; exit 3; fi
  if [ "$would_run" = 0 ]; then echo "✖ Dry run: no runnable reviewers (none installed / all excluded)." >&2; exit 3; fi
  echo "✔ Dry run complete (config valid; $would_run reviewer(s) would run)."; exit 0
fi

# A real round that actually ran reviewers consumes one cap slot — whatever the
# verdict below (a persistently failing/flaky reviewer must still hit the cap).
# A round where nobody ran (misconfig) is NOT consumed (it exits 3 later).
[ "$ran" -gt 0 ] && echo $((ROUND + 1)) > "$ROUND_FILE"

# SHA binding is fail-closed: we must be able to read HEAD before AND after. If
# either read fails we cannot prove HEAD stayed put, so we do NOT pass.
NEW_SHA=$(gh pr view "$PR" --json headRefOid -q .headRefOid 2>/dev/null || true)
if [ -z "$HEAD_SHA" ] || [ -z "$NEW_SHA" ]; then
  echo "✖ Could not read PR head SHA (${HEAD_SHA:+start ok}${HEAD_SHA:-start FAILED}/${NEW_SHA:+end ok}${NEW_SHA:-end FAILED}): cannot prove HEAD stability. Re-run." >&2
  exit 3
fi
if [ "$HEAD_SHA" != "$NEW_SHA" ]; then
  echo "✖ HEAD moved during the round (${HEAD_SHA:0:7} → ${NEW_SHA:0:7}): reviews are stale. Re-run." >&2
  exit 3
fi

if [ "$ran" = 0 ]; then
  echo "✖ No reviewers ran — cannot form consensus from nobody. Check installed CLIs / --reviewers." >&2
  exit 3
fi
if [ "$failed" -gt 0 ]; then
  echo "✖ Relay round NOT clean: $failed/$ran reviewer(s) failed —$failed_names. Fix and re-run." >&2
  exit 3
fi
echo "✔ Relay done — $ran/$ran reviewer(s) posted${skipped:+, $skipped skipped (not installed)}, reviewed sha ${HEAD_SHA:0:7}."
[ "$skipped" -gt 0 ] && echo "  ⚠ $skipped default reviewer(s) were skipped — this was NOT a full cross-review." >&2
echo "  This confirms every reviewer RAN, not that the PR is approved: read the reviews and"
echo "  resolve every Blocker/Should-fix before merging."
exit 0
